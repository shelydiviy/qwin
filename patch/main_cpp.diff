diff --git a/src/main.cpp b/src/main.cpp
--- a/src/main.cpp
+++ b/src/main.cpp
@@ -1,5 +1,24 @@
 #include <asio.hpp>
+#include <thread>
+#include <vector>
+
+void worker(asio::io_context& ioContext) {
+    ioContext.run();
+}
+
+void initializeThreadPool(asio::io_context& ioContext, size_t numThreads) {
+    std::vector<std::thread> threads;
+    for (size_t i = 0; i < numThreads; ++i) {
+        threads.emplace_back(worker, std::ref(ioContext));
+    }
+
+    for (auto& t : threads) {
+        if (t.joinable()) {
+            t.join();
+        }
+    }
+}
+
 int main() {
     asio::io_context ioContext;
+    size_t numThreads = std::thread::hardware_concurrency(); // Количество ядер процессора
+    initializeThreadPool(ioContext, numThreads);
     return 0;
 }
