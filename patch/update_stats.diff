diff --git a/src/networking.cpp b/src/networking.cpp
--- a/src/networking.cpp
+++ b/src/networking.cpp
@@ -1,3 +1,21 @@
+#include "networking.h"
+
+void sendServerUpdate(const asio::ip::udp::endpoint& masterEndpoint) {
+    std::vector<uint8_t> buffer;
+    // TODO: Заполнить buffer данными о состоянии сервера
+
+    socket.async_send_to(
+        asio::buffer(buffer), masterEndpoint,
+        [](std::error_code ec, [[maybe_unused]] std::size_t /*bytesSent*/) {
+            if (ec) logMessage("Ошибка отправки обновления состояния: " + ec.message(), "error");
+        });
+}
+
+void startUpdateTimer(asio::io_context& ioContext, const asio::ip::udp::endpoint& masterEndpoint) {
+    asio::steady_timer timer(ioContext, asio::chrono::minutes(5)); // Каждые 5 минут
+    timer.async_wait([&](std::error_code ec) {
+        if (!ec) {
+            sendServerUpdate(masterEndpoint);
+            startUpdateTimer(ioContext, masterEndpoint); // Запускаем таймер заново
+        }
+    });
+}

