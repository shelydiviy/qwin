diff --git a/src/config.cpp b/src/config.cpp
--- a/src/config.cpp
+++ b/src/config.cpp
@@ -1,3 +1,22 @@
+#include "config.h"
+#include <nlohmann/json.hpp>
+#include <fstream>
+
+nlohmann::json readConfig(const std::string& filePath) {
+    std::ifstream file(filePath);
+    if (!file.is_open()) throw std::runtime_error("Не удалось открыть файл конфигурации");
+    nlohmann::json config;
+    file >> config;
+    return config;
+}
+
+void loadServerSettings(const std::string& filePath) {
+    try {
+        auto config = readConfig(filePath);
+        std::string serverName = config["server_name"];
+        std::string gameMode = config["game_mode"];
+        logMessage("Загружены настройки сервера: " + serverName, "info");
+    } catch (const std::exception& e) {
+        logMessage("Ошибка загрузки конфигурации: " + std::string(e.what()), "error");
+    }
+}

