diff --git a/src/networking.cpp b/src/networking.cpp
--- a/src/networking.cpp
+++ b/src/networking.cpp
@@ -1,3 +1,21 @@
+#include <unordered_set>
+#include <string>
+
+std::unordered_set<std::string> blockedIPs;
+
+bool isIPBlocked(const std::string& ip) {
+    return blockedIPs.find(ip) != blockedIPs.end();
+}
+
+void blockIP(const std::string& ip) {
+    blockedIPs.insert(ip);
+    logMessage("IP-адрес " + ip + " заблокирован", "info");
+}
+
+void handleIncomingConnection(const asio::ip::udp::endpoint& endpoint) {
+    std::string clientIP = endpoint.address().to_string();
+    if (isIPBlocked(clientIP)) {
+        logMessage("Подключение от заблокированного IP: " + clientIP, "warning");
+        return;
+    }
+    // Обработка подключения
+}

